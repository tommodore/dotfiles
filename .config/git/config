[user]
    name = Your Name
    email = your@email.com
    signingkey = 

[core]
    editor = nvim
    pager = delta --dark --line-numbers --side-by-side
    excludesfile = ~/.config/git/ignore

[init]
    defaultBranch = main

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = true

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    lg = log --oneline --graph --decorate --all
    last = log -1 --stat
    undo = reset --soft HEAD~1
    amend = commit --amend --no-edit
    graph = log --all --decorate --oneline --graph
    unstage = reset HEAD --
    diffc = diff --cached

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true

[interactive]
    diffFilter = delta --color-only

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
    tool = delta

[credential]
    helper = osxkeychain
